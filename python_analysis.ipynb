import pandas as pd
import matplotlib.pyplot as plt

# Load Datset
data = pd.read_csv("nhs_waiting_times.csv")

# View first rows
print (data.head())

# Average waiting time by department
avg_wait = data.groupby("Department")["Average_Wait_Time"].mean()

print (avg_wait)

# Plot average waiting time
avg.wait.plot(kind="bar")
plt.title("Average Waiting TIme by Department")
plt.xlabel("Department")
plt.ylabel("Average wait Time")
plt.show()
